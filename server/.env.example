NODE_ENV=development
HOST=127.0.0.1
PORT=3000
DATABASE_URL=postgresql://servora:servora@localhost:5432/servora_med
LOG_LEVEL=info
CORS_ORIGIN=http://127.0.0.1:5173
SESSION_TTL_SECONDS=28800
LOGIN_RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000

# One-time production/admin bootstrap. Never commit real values.
BOOTSTRAP_ORGANIZATION_NAME=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Development seed only. Creates admin/manager/staff demo users.
DEV_SEED_ORGANIZATION_NAME=Servora Med Demo
DEV_SEED_PASSWORD=
