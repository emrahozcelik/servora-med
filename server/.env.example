NODE_ENV=development
HOST=127.0.0.1
PORT=3000
DATABASE_URL=postgresql://servora:servora@localhost:5432/servora_med
LOG_LEVEL=info
CORS_ORIGIN=http://127.0.0.1:5173
SESSION_TTL_SECONDS=28800
LOGIN_RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000
# Production: required. Allowed: loopback | 127.0.0.1 | ::1
TRUSTED_PROXY=loopback
# Production: required exact schema_migrations.version for readiness
# Development/test: optional
HEALTH_SCHEMA_VERSION=
# Fail-closed Phase Q gate. Keep false until disclosure, retention, and provider approval.
ACTION_SCOPED_GEOLOCATION_ENABLED=false
# Fail-closed Phase R gate. Install guidance remains available while disabled.
WEB_PUSH_ENABLED=false
# Required only when WEB_PUSH_ENABLED=true. Generate one VAPID pair outside Git.
# Keep the private key only in the root-owned production environment file.
WEB_PUSH_VAPID_SUBJECT=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# Production notes:
# - CORS_ORIGIN must be a single https origin (no path)
# - HOST must be 127.0.0.1 or ::1
# - HEALTH_SCHEMA_VERSION is required (e.g. 014_create_web_push)
# - Secrets come from /etc/servora-med/servora-med.env, not a repo .env
# - Never commit generated VAPID keys

# One-time production/admin bootstrap. Never commit real values.
BOOTSTRAP_ORGANIZATION_NAME=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Development seed only. Creates admin/manager/staff demo users.
DEV_SEED_ORGANIZATION_NAME=Servora Med Demo
DEV_SEED_PASSWORD=
