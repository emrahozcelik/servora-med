{
  "name": "servora-med-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Servora-Med Fastify API",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "start:prod": "node dist/index.js",
    "migrate": "tsx --env-file=.env src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "bootstrap:admin": "tsx --env-file=.env src/db/bootstrap-admin.ts",
    "bootstrap:admin:prod": "node dist/db/bootstrap-admin.js",
    "db:seed:dev": "tsx --env-file=.env src/db/seed-dev.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "11.1.1",
    "@fastify/cors": "11.3.0",
    "@fastify/rate-limit": "11.1.0",
    "fastify": "5.10.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/pg": "8.20.0",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
