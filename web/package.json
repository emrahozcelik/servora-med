{
  "name": "servora-med-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Servora-Med React web application",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "smoke:responsive": "node scripts/responsive-smoke.mjs",
    "bundle:report": "node scripts/report-bundle-sizes.mjs",
    "bundle:check": "BUNDLE_ENFORCE=1 node scripts/report-bundle-sizes.mjs"
  },
  "dependencies": {
    "antd": "6.5.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "28.1.0",
    "playwright": "^1.55.1",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
