# Install as /etc/servora-med/servora-med.env (root:servora-med, mode 0640).
# Never commit real secrets.
# Canonical pilot DB auth: password-bearing DATABASE_URL (not peer trust, not PGPASSFILE).
# Password must be URL-safe (preferred: openssl rand -hex 32) or percent-encoded in the URL.

NODE_ENV=production
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info

# Single exact https origin for the public FQDN (no path).
CORS_ORIGIN=https://app.example.com

# Application role + password. Replace <APP_DB_PASSWORD> with a URL-safe secret
# (canonical generator: openssl rand -hex 32) or a percent-encoded password.
# Readable only by root and group servora-med (mode 0640). Never put the password on argv.
DATABASE_URL=postgresql://servora:<APP_DB_PASSWORD>@127.0.0.1:5432/servora_med

SESSION_TTL_SECONDS=28800
LOGIN_RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000

# Required in production. loopback | 127.0.0.1 | ::1
TRUSTED_PROXY=loopback

# Required in production. Exact schema_migrations.version for readiness.
HEALTH_SCHEMA_VERSION=007_sales_meeting
