# Install as /etc/servora-med/servora-med-backup.env (root:servora-med, mode 0640).
# Required by backup LaunchDaemon / systemd unit — missing file fails the unit.
# Password material must match the APP_DB_PASSWORD used in DATABASE_URL (same secret).

BACKUP_DIR=/var/backups/servora-med
OPS_LOG=/var/log/servora-med/backup-ops.log

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=servora
PGDATABASE=servora_med
# Same application password as DATABASE_URL (not a second store; mode 0640).
PGPASSWORD=<APP_DB_PASSWORD>

# Absolute client binaries — required by ops/launchd/run-backup.sh.example.
# launchd does not load interactive Homebrew PATH; bare `pg_dump` is unsafe.
#
# Apple Silicon Homebrew (postgresql@16):
PG_DUMP_BIN=/opt/homebrew/opt/postgresql@16/bin/pg_dump
PG_RESTORE_BIN=/opt/homebrew/opt/postgresql@16/bin/pg_restore
PSQL_BIN=/opt/homebrew/opt/postgresql@16/bin/psql
#
# Intel Homebrew example (comment Apple Silicon lines and use these):
# PG_DUMP_BIN=/usr/local/opt/postgresql@16/bin/pg_dump
# PG_RESTORE_BIN=/usr/local/opt/postgresql@16/bin/pg_restore
# PSQL_BIN=/usr/local/opt/postgresql@16/bin/psql
#
# Ubuntu / PGDG example:
# PG_DUMP_BIN=/usr/lib/postgresql/17/bin/pg_dump
# PG_RESTORE_BIN=/usr/lib/postgresql/17/bin/pg_restore
# PSQL_BIN=/usr/lib/postgresql/17/bin/psql

# Optional: absolute path to an executable that receives dump and checksum paths.
# OFFSITE_COPY_HOOK=/usr/local/bin/servora-med-offsite-copy
