# Install as /etc/servora-med/servora-med-backup.env (root:servora-med, mode 0640).
# Required by servora-med-backup.service — missing file fails the unit.

BACKUP_DIR=/var/backups/servora-med
OPS_LOG=/var/log/servora-med/backup-ops.log

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=servora
PGDATABASE=servora_med

# Optional: absolute path to an executable that receives dump and checksum paths.
# OFFSITE_COPY_HOOK=/usr/local/bin/servora-med-offsite-copy

# Prefer PGPASSFILE for password material (mode 0600), not argv.
# PGPASSFILE=/etc/servora-med/.pgpass
